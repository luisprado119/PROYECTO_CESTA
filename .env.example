# =========================
# PROYECTO CESTA - PLANTILLA DE ENTORNO
# =========================

# 1) Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_NAME=cesta_db
DB_USER=cesta_user
DB_PASSWORD=tu_password
DB_CONNECTION_URL=postgresql://cesta_user:tu_password@localhost:5433/cesta_db

# 2) API backend local
API_PORT=3000
API_BASE_URL=http://localhost:3000
API_PRODUCTS_RAW_URL=http://localhost:3000/products

# 3) Red Ethereum local (Geth + MetaMask)
ETH_NETWORK_NAME=Cesta Local
ETH_CHAIN_ID=1337
ETH_NETWORK_ID=1337
ETH_RPC_URL=http://127.0.0.1:8545
ETH_HTTP_PORT=8545
ETH_WS_PORT=8546
ETH_CURRENCY_SYMBOL=ETH
ETH_BLOCK_EXPLORER_URL=
ETH_BLOCK_TIME=5

# 4) Firmante local del nodo (Clique)
ETH_SIGNER_ADDRESS=0xTU_SIGNER_LOCAL
ETH_SIGNER_PASSWORD_FILE=/blockchain/password.txt

# 5) Cuentas MetaMask para pruebas
METAMASK_ACCOUNT_1=0xTU_CUENTA_1
METAMASK_ACCOUNT_2=0xTU_CUENTA_2
METAMASK_PRIVATE_KEY_1=<PRIVATE_KEY_1>
METAMASK_PRIVATE_KEY_2=<PRIVATE_KEY_2>

# 6) Variables Vite (frontend)
VITE_MERCHANT_ADDRESS=0xTU_CUENTA_COMERCIO
VITE_ETH_USD_RATE=3000
